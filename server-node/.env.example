# IoT Platform Server Configuration
# Copy this file to .env and adjust values

# Server
PORT=5000
DB_PATH=iot_data.db

# Security
CORS_ORIGINS=                    # comma-separated origins, empty = allow all (dev mode)
MASTER_API_KEY=                  # optional fallback API key (set for easy device transition)

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes
RATE_LIMIT_MAX=100               # general API requests per window
RATE_LIMIT_SENSOR_MAX=500        # sensor data requests per window (higher)

# MQTT Bridge (optional - leave MQTT_HOST empty to disable)
MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC_PREFIX=iot
